generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id          String    @id @default(cuid())
  email       String    @unique
  nome        String
  senhaHash   String    @map("senha_hash")
  role        String    @default("admin") // superadmin | admin | viewer
  ativo       Boolean   @default(true)
  ultimoLogin DateTime? @map("ultimo_login")
  criadoEm    DateTime  @default(now()) @map("criado_em")

  @@map("admin_users")
}

// ─── Plataforma Multi-Sided ───

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  nome         String
  senhaHash    String?   @map("senha_hash")
  googleId     String?   @unique @map("google_id")
  role         String    @default("empresa") // admin | empresa | parceiro
  avatar       String?
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now()) @map("criado_em")
  ultimoLogin  DateTime? @map("ultimo_login")

  company      Company?  @relation("CompanyOwner")
  memberships  CompanyMember[]
  opportunities Opportunity[]
  matchesFrom  Match[]   @relation("MatchFrom")
  matchesTo    Match[]   @relation("MatchTo")
  messages        Message[]
  apiKeys         ApiKey[]
  notifications   UserNotification[]
  reviewsFeitas   Review[] @relation("ReviewsFeitas")
  reviewsRecebidas Review[] @relation("ReviewsRecebidas")

  @@map("users")
  @@index([email])
  @@index([role])
}

model Company {
  id          String    @id @default(cuid())
  slug        String    @unique
  nome        String
  tagline     String?
  descricao   String?   @db.Text
  setor       String
  pais        String
  cidade      String?
  website     String?
  linkedin    String?
  logo        String?
  estagio     String    @default("operando") // ideacao | validacao | operando | escala | consolidado
  faturamento String?   // faixa: "ate-100k" | "100k-500k" | "500k-1m" | "1m-5m" | "5m+"
  interesses  String[]  // tags: ["expansao", "investimento", "fornecedor", "franquia", "mentoria"]
  verificada  Boolean   @default(false)
  ativa       Boolean   @default(true)
  criadoEm    DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  ownerId     String    @unique @map("owner_id")
  owner       User      @relation("CompanyOwner", fields: [ownerId], references: [id])
  members     CompanyMember[]
  opportunities Opportunity[]
  projects    ProjectMember[]
  subscription Subscription?
  teamInvites TeamInvite[]
  documents   Document[]

  @@map("companies")
  @@index([slug])
  @@index([setor])
  @@index([verificada])
}

model CompanyMember {
  id        String   @id @default(cuid())
  role      String   @default("membro") // dono | admin | membro
  criadoEm  DateTime @default(now()) @map("criado_em")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("company_members")
}

model Opportunity {
  id          String    @id @default(cuid())
  titulo      String
  tipo        String    // franquia | investimento | parceria | fornecedor | expansao
  setor       String
  descricao   String    @db.Text
  requisitos  String?   @db.Text
  budget      String?   // faixa de investimento
  localizacao String?
  status      String    @default("aberta") // aberta | em-negociacao | fechada | cancelada
  destaque    Boolean   @default(false)
  criadoEm    DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  expiraEm    DateTime? @map("expira_em")

  companyId   String    @map("company_id")
  company     Company   @relation(fields: [companyId], references: [id])
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  matches     Match[]

  @@map("opportunities")
  @@index([companyId])
  @@index([status])
  @@index([tipo])
  @@index([criadoEm])
}

model Match {
  id          String    @id @default(cuid())
  status      String    @default("sugerido") // sugerido | aceito | recusado | em-conversa | fechado
  score       Int?      // 0-100 match score da IA
  motivo      String?   @db.Text // razão da sugestão da IA
  criadoEm    DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  opportunityId String  @map("opportunity_id")
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  fromUserId    String  @map("from_user_id")
  fromUser      User    @relation("MatchFrom", fields: [fromUserId], references: [id])
  toUserId      String  @map("to_user_id")
  toUser        User    @relation("MatchTo", fields: [toUserId], references: [id])
  messages      Message[]
  project       PlatformProject?

  @@unique([opportunityId, fromUserId, toUserId])
  @@map("matches")
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
}

model PlatformProject {
  id          String    @id @default(cuid())
  nome        String
  descricao   String?   @db.Text
  status      String    @default("ativo") // ativo | pausado | concluido | cancelado
  criadoEm    DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  matchId     String    @unique @map("match_id")
  match       Match     @relation(fields: [matchId], references: [id])
  members     ProjectMember[]
  tasks       ProjectTask[]
  reviews     Review[]

  @@map("platform_projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      String   @default("membro") // lider | membro
  criadoEm  DateTime @default(now()) @map("criado_em")

  projectId String   @map("project_id")
  project   PlatformProject @relation(fields: [projectId], references: [id])
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([projectId, companyId])
  @@map("project_members")
}

model ProjectTask {
  id          String    @id @default(cuid())
  titulo      String
  descricao   String?   @db.Text
  status      String    @default("pendente") // pendente | em-progresso | concluida
  prioridade  String    @default("media") // baixa | media | alta
  prazo       DateTime?
  criadoEm    DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  projectId   String    @map("project_id")
  project     PlatformProject @relation(fields: [projectId], references: [id])

  @@map("project_tasks")
}

model Message {
  id        String   @id @default(cuid())
  conteudo  String   @db.Text
  criadoEm  DateTime @default(now()) @map("criado_em")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id])

  @@map("messages")
  @@index([matchId])
  @@index([userId])
}

model Candidatura {
  id                String   @id @default(cuid())
  criadoEm          DateTime @default(now()) @map("criado_em")
  status            String   @default("nova")
  nome              String
  email             String
  telefone          String
  pais              String
  cidade            String
  perfil            String
  experiencia       String   @db.Text
  setor             String
  empresaAtual      String?  @map("empresa_atual")
  linkedin          String?
  modelo            String[]
  capitalDisponivel String   @map("capital_disponivel")
  prazo             String
  dedicacao         String
  motivacao         String   @db.Text
  diferenciais      String   @db.Text
  disponibilidade   String?
  aceitaNDA         Boolean  @default(false) @map("aceita_nda")
  notas             String?  @db.Text
  atribuidoA        String?  @map("atribuido_a")
  score             Int?
  scoreTier         String?  @map("score_tier")
  scoreBreakdown    Json?    @map("score_breakdown")
  scoreFlags        String[] @map("score_flags")
  ndaAceitoEm       DateTime? @map("nda_aceito_em")
  ndaIp             String?   @map("nda_ip")
  ndaUserAgent      String?   @map("nda_user_agent")

  @@map("candidaturas")
}

model Contato {
  id        String   @id @default(cuid())
  criadoEm  DateTime @default(now()) @map("criado_em")
  lido      Boolean  @default(false)
  arquivado Boolean  @default(false)
  nome      String
  email     String
  empresa   String?
  tipo      String
  orcamento String?
  mensagem  String   @db.Text
  notas     String?  @db.Text

  @@map("contatos")
}

model Projeto {
  slug              String    @id
  name              String
  tagline           String
  description       String    @db.Text
  detalhes          String[]
  tag               String
  status            String
  mercado           String
  parceiro          String?
  controle          String
  icon              String
  socio             String?
  porcentagem       Float?
  notasInternas     String?   @map("notas_internas") @db.Text
  ultimaAtualizacao DateTime? @map("ultima_atualizacao")

  @@map("projetos")
}

model Termo {
  slug      String @id
  termo     String
  definicao String @db.Text
  categoria String

  @@map("glossario")
}

model Artigo {
  slug      String   @id
  titulo    String
  resumo    String   @db.Text
  conteudo  String[]
  categoria String
  destaque  Boolean  @default(false)

  @@map("artigos")
}

model AiConversa {
  id        String   @id @default(cuid())
  titulo    String
  resumo    String   @db.Text
  mensagens Json
  criadoEm  DateTime @default(now()) @map("criado_em")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ai_conversas")
}

model Parceiro {
  id            String   @id @default(cuid())
  nome          String
  email         String   @unique
  token         String   @unique
  projetoSlug   String   @map("projeto_slug")
  papel         String   @default("operador")
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")
  ultimoAcesso  DateTime? @map("ultimo_acesso")
  metricas      Json?

  @@map("parceiros")
}

model ReuniaoDataset {
  id        String   @id @default(cuid())
  tipo      String   @unique
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("reuniao_datasets")
}

// ─── Pagamentos e Assinaturas ───

model Subscription {
  id              String    @id @default(cuid())
  plano           String    // free | growth | enterprise
  status          String    @default("active") // active | canceled | past_due | trialing
  stripeCustomerId    String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  currentPeriodEnd    DateTime? @map("current_period_end")
  cancelAtPeriodEnd   Boolean   @default(false) @map("cancel_at_period_end")
  criadoEm        DateTime  @default(now()) @map("criado_em")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  companyId       String    @unique @map("company_id")
  company         Company   @relation(fields: [companyId], references: [id])

  @@map("subscriptions")
}

model Payment {
  id              String    @id @default(cuid())
  amount          Int       // centavos
  currency        String    @default("eur")
  status          String    // succeeded | pending | failed
  tipo            String    // subscription | commission | service
  descricao       String?
  stripePaymentId String?   @unique @map("stripe_payment_id")
  criadoEm        DateTime  @default(now()) @map("criado_em")

  companyId       String    @map("company_id")

  @@map("payments")
}

// ─── API Keys (acesso externo) ───

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique
  nome        String    // nome descritivo
  scopes      String[]  // companies:read | opportunities:read | opportunities:write | matches:read
  ativa       Boolean   @default(true)
  ultimoUso   DateTime? @map("ultimo_uso")
  criadoEm    DateTime  @default(now()) @map("criado_em")

  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])

  @@map("api_keys")
}

// ─── Admin Enterprise ───

model AuditLog {
  id         String   @id @default(cuid())
  acao       String   // create | update | delete | login | export
  recurso    String   // user | company | opportunity | match | subscription | admin
  resourceId String?  @map("resource_id")
  adminId    String   @map("admin_id")
  adminNome  String   @map("admin_nome")
  detalhes   Json?
  ip         String?
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@map("audit_logs")
  @@index([recurso, criadoEm])
  @@index([adminId, criadoEm])
}

model AdminNotification {
  id       String   @id @default(cuid())
  tipo     String   // new-user | new-candidatura | deal-closed | payment
  titulo   String
  mensagem String
  link     String?
  lida     Boolean  @default(false)
  criadoEm DateTime @default(now()) @map("criado_em")

  @@map("admin_notifications")
  @@index([lida, criadoEm])
}

model PlatformConfig {
  chave     String   @id
  valor     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_config")
}

// ─── Team Invites ───

model TeamInvite {
  id        String   @id @default(cuid())
  email     String
  role      String   @default("membro") // dono | admin | membro
  token     String   @unique
  aceito    Boolean  @default(false)
  criadoEm  DateTime @default(now()) @map("criado_em")
  expiraEm  DateTime @map("expira_em")

  empresaId String   @map("empresa_id")
  empresa   Company  @relation(fields: [empresaId], references: [id])

  @@map("team_invites")
  @@index([token])
  @@index([empresaId])
}

// ─── User Notifications ───

model UserNotification {
  id       String   @id @default(cuid())
  tipo     String   // match | message | invite | review | system
  titulo   String
  mensagem String
  link     String?
  lida     Boolean  @default(false)
  criadoEm DateTime @default(now()) @map("criado_em")

  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id])

  @@map("user_notifications")
  @@index([userId, lida, criadoEm])
}

// ─── Reviews ───

model Review {
  id          String   @id @default(cuid())
  nota        Int      // 1-5
  comentario  String?  @db.Text
  criadoEm    DateTime @default(now()) @map("criado_em")

  projetoId   String   @map("projeto_id")
  projeto     PlatformProject @relation(fields: [projetoId], references: [id])
  autorId     String   @map("autor_id")
  autor       User     @relation("ReviewsFeitas", fields: [autorId], references: [id])
  avaliadoId  String   @map("avaliado_id")
  avaliado    User     @relation("ReviewsRecebidas", fields: [avaliadoId], references: [id])

  @@unique([projetoId, autorId])
  @@map("reviews")
  @@index([avaliadoId])
}

// ─── Documents (verificacao) ───

model Document {
  id        String   @id @default(cuid())
  tipo      String   // nif | certidao | contrato | outro
  nome      String
  url       String
  status    String   @default("pendente") // pendente | aprovado | rejeitado
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresaId String   @map("empresa_id")
  empresa   Company  @relation(fields: [empresaId], references: [id])

  @@map("documents")
  @@index([empresaId])
}

// ─── Stripe Event Idempotency ───

model StripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique @map("event_id") // Stripe event ID (evt_xxx)
  type        String   // checkout.session.completed, etc.
  processed   Boolean  @default(true)
  criadoEm    DateTime @default(now()) @map("criado_em")

  @@map("stripe_events")
  @@index([eventId])
}
