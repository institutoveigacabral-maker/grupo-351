# ============================================
# GRUPO +351 — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha os valores

# --- Banco de Dados (obrigatório) ---
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# --- Admin (obrigatório) ---
ADMIN_SECRET="sua-chave-secreta-para-hmac"

# --- WhatsApp (opcional) ---
# Número com código do país, sem espaços (ex: 351912345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# --- Analytics Umami (opcional, RGPD compliant) ---
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""

# --- Email Transacional Resend (opcional) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="contato@grupo351.com"
ADMIN_NOTIFICATION_EMAIL="admin@grupo351.com"

# --- IA (opcional — Gemini por padrão) ---
AI_PROVIDER=""  # "gemini" (default) ou "anthropic"
GOOGLE_API_KEY=""
ANTHROPIC_API_KEY=""

# --- CRM (opcional — HubSpot ou Pipedrive) ---
CRM_PROVIDER=""  # "hubspot" ou "pipedrive"
HUBSPOT_API_KEY=""
PIPEDRIVE_API_TOKEN=""

# --- Google OAuth (opcional — login com Google) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stripe (obrigatório para planos pagos) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Observabilidade Sentry (opcional) ---
NEXT_PUBLIC_SENTRY_DSN=""

# --- Redis / Upstash (opcional — cache e rate limiting) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Reunioes API (opcional) ---
REUNIOES_TOKEN=""

# ============================================
# NOTA DE SEGURANCA:
# - ADMIN_SECRET deve ter no minimo 16 caracteres (recomendado: 64 hex chars)
# - Gere com: openssl rand -hex 32
# - NUNCA commitar .env ou .env.local no git
# ============================================
